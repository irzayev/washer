// =============================================================
// eDetailing CRM — Prisma schema
// Single-tenant, multi-branch. All money in Decimal(12,2) AZN.
// All timestamps stored in UTC; display TZ = Asia/Baku.
// =============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto]
}

// =============================================================
// Enums
// =============================================================

enum UserRole {
  ADMIN
  MANAGER
  WORKER
  CLIENT
}

enum VatMode {
  NONE
  INCLUDED
  ADDED
}

enum VipTier {
  NONE
  SILVER
  GOLD
  PLATINUM
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  NO_SHOW
  CONVERTED
}

enum AppointmentSource {
  MANAGER
  WEB
  WHATSAPP
  INSTAGRAM
  PHONE
}

enum OrderStatus {
  NEW
  SCHEDULED
  IN_PROGRESS
  WAITING
  COMPLETED
  DELIVERED
  CANCELLED
}

enum OrderItemStatus {
  PENDING
  IN_PROGRESS
  DONE
  SKIPPED
}

enum DiscountType {
  FIXED
  PERCENT
  MANUAL
}

enum PaymentMethod {
  CASH
  POS
  AZERICARD
  TRANSFER
  BONUS
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  SUCCEEDED
  FAILED
  REFUNDED
  CANCELLED
}

enum BonusTxType {
  EARN
  SPEND
  EXPIRE
  ADJUST
  REFUND
}

enum StockMovementType {
  RECEIPT
  USAGE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  WRITE_OFF
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum PayrollModelType {
  FIXED
  PERCENT
  PERCENT_PLUS_BONUS
  KPI
}

enum CashShiftStatus {
  OPEN
  CLOSED
}

enum PromotionType {
  PERCENT_OFF
  FIXED_OFF
  BUNDLE
}

// =============================================================
// Platform: Branches, Boxes, Users, RBAC, Audit
// =============================================================

model Branch {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  code         String   @unique
  address      String?
  phone        String?
  timezone     String   @default("Asia/Baku")
  vatMode      VatMode  @default(INCLUDED)
  vatRate      Decimal  @default(18.00) @db.Decimal(5, 2)
  currency     String   @default("AZN")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  users          User[]
  boxes          Box[]
  clients        Client[]
  services       Service[]
  appointments   Appointment[]
  orders         Order[]
  payments       Payment[]
  inventoryItems InventoryItem[]
  stockMovements StockMovement[]
  cashShifts     CashShift[]
  salaryRuns     SalaryRun[]
  promotions     Promotion[]

  @@index([isActive])
}

model Box {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String   @db.Uuid
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch Branch  @relation(fields: [branchId], references: [id], onDelete: Restrict)
  orders Order[]

  @@unique([branchId, name])
  @@index([branchId])
}

model User {
  id           String    @id @default(uuid()) @db.Uuid
  branchId     String?   @db.Uuid
  email        String    @unique
  phone        String?   @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole  @default(MANAGER)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch          Branch?          @relation(fields: [branchId], references: [id])
  refreshTokens   RefreshToken[]
  ordersAssigned  Order[]          @relation("OrderAssignee")
  orderItemsAssigned OrderItem[]   @relation("OrderItemExecutor")
  discountsApplied Discount[]      @relation("DiscountApplier")
  auditLogs       AuditLog[]
  payrollProfile  PayrollProfile?
  cashShifts      CashShift[]      @relation("CashShiftOpener")
  cashShiftsClosed CashShift[]     @relation("CashShiftCloser")

  @@index([role])
  @@index([branchId])
}

model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  action     String
  entity     String
  entityId   String?
  diff       Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// =============================================================
// CRM: Clients & Vehicles
// =============================================================

model Client {
  id           String    @id @default(uuid()) @db.Uuid
  branchId     String    @db.Uuid
  phone        String
  firstName    String
  lastName     String?
  email        String?
  birthday     DateTime? @db.Date
  vipTier      VipTier   @default(NONE)
  notes        String?
  tags         String[]  @default([])
  preferredLang String   @default("ru")
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  vehicles      Vehicle[]
  orders        Order[]
  appointments  Appointment[]
  bonusWallet   BonusWallet?
  bonusTxs      BonusTransaction[]

  @@unique([branchId, phone])
  @@index([branchId])
  @@index([vipTier])
}

model Vehicle {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @db.Uuid
  plate     String?
  vin       String?
  make      String?
  model     String?
  year      Int?
  color     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orders       Order[]
  appointments Appointment[]

  @@index([clientId])
  @@index([plate])
}

// =============================================================
// Catalog: Categories, Services, Packages, Promotions
// =============================================================

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  parentId  String?  @db.Uuid
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  services Service[]
}

model Service {
  id          String   @id @default(uuid()) @db.Uuid
  branchId    String?  @db.Uuid
  categoryId  String   @db.Uuid
  name        String
  description String?
  basePrice   Decimal  @db.Decimal(12, 2)
  vatRate     Decimal? @db.Decimal(5, 2)
  durationMin Int      @default(30)
  isActive    Boolean  @default(true)
  bonusEligible Boolean @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch       Branch?              @relation(fields: [branchId], references: [id])
  category     Category             @relation(fields: [categoryId], references: [id])
  consumption  ServiceConsumption[]
  packageItems PackageItem[]
  orderItems   OrderItem[]

  @@index([categoryId])
  @@index([branchId])
  @@index([isActive])
}

model ServicePackage {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items PackageItem[]
}

model PackageItem {
  id        String   @id @default(uuid()) @db.Uuid
  packageId String   @db.Uuid
  serviceId String   @db.Uuid
  qty       Int      @default(1)

  package ServicePackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service Service        @relation(fields: [serviceId], references: [id], onDelete: Restrict)

  @@unique([packageId, serviceId])
}

model Promotion {
  id          String        @id @default(uuid()) @db.Uuid
  branchId    String?       @db.Uuid
  name        String
  code        String?       @unique
  type        PromotionType
  value       Decimal       @db.Decimal(12, 2)
  startsAt    DateTime
  endsAt      DateTime
  conditions  Json?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  branch Branch? @relation(fields: [branchId], references: [id])

  @@index([startsAt, endsAt])
}

// =============================================================
// Operations: Appointments, Orders, Items, Discounts
// =============================================================

model Appointment {
  id         String            @id @default(uuid()) @db.Uuid
  branchId   String            @db.Uuid
  clientId   String            @db.Uuid
  vehicleId  String?           @db.Uuid
  slotStart  DateTime
  slotEnd    DateTime
  status     AppointmentStatus @default(PENDING)
  source     AppointmentSource @default(MANAGER)
  serviceIds String[]          @default([])
  notes      String?
  orderId    String?           @unique @db.Uuid
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  branch  Branch   @relation(fields: [branchId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])
  vehicle Vehicle? @relation(fields: [vehicleId], references: [id])
  order   Order?   @relation(fields: [orderId], references: [id])

  @@index([branchId, slotStart])
  @@index([clientId])
  @@index([status])
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  number          String      @unique
  branchId        String      @db.Uuid
  clientId        String      @db.Uuid
  vehicleId       String?     @db.Uuid
  boxId           String?     @db.Uuid
  assignedToId    String?     @db.Uuid
  status          OrderStatus @default(NEW)
  subtotal        Decimal     @default(0) @db.Decimal(12, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(12, 2)
  bonusUsed       Decimal     @default(0) @db.Decimal(12, 2)
  vatTotal        Decimal     @default(0) @db.Decimal(12, 2)
  grandTotal      Decimal     @default(0) @db.Decimal(12, 2)
  bonusEarned     Decimal     @default(0) @db.Decimal(12, 2)
  notes           String?
  version         Int         @default(0)
  openedAt        DateTime    @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?
  deletedAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  branch     Branch        @relation(fields: [branchId], references: [id])
  client     Client        @relation(fields: [clientId], references: [id])
  vehicle    Vehicle?      @relation(fields: [vehicleId], references: [id])
  box        Box?          @relation(fields: [boxId], references: [id])
  assignee   User?         @relation("OrderAssignee", fields: [assignedToId], references: [id])
  items      OrderItem[]
  payments   Payment[]
  discounts  Discount[]
  bonusTxs   BonusTransaction[]
  stockMovements StockMovement[]
  appointment Appointment?
  invoice    Invoice?

  @@index([branchId, status])
  @@index([clientId])
  @@index([status])
  @@index([openedAt])
}

model OrderItem {
  id            String          @id @default(uuid()) @db.Uuid
  orderId       String          @db.Uuid
  serviceId     String          @db.Uuid
  priceSnapshot Decimal         @db.Decimal(12, 2)
  qty           Int             @default(1)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  executorId    String?         @db.Uuid
  status        OrderItemStatus @default(PENDING)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  order        Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  service      Service             @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  executor     User?               @relation("OrderItemExecutor", fields: [executorId], references: [id])
  materialsUsed OrderMaterialUsage[]

  @@index([orderId])
}

model Discount {
  id          String       @id @default(uuid()) @db.Uuid
  orderId     String       @db.Uuid
  type        DiscountType
  value       Decimal      @db.Decimal(12, 2)
  reason      String
  comment     String?
  appliedById String       @db.Uuid
  createdAt   DateTime     @default(now())

  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  appliedBy User  @relation("DiscountApplier", fields: [appliedById], references: [id])

  @@index([orderId])
}

// =============================================================
// Finance: Payments, Refunds, Invoices, Cash shifts
// =============================================================

model Payment {
  id              String        @id @default(uuid()) @db.Uuid
  orderId         String        @db.Uuid
  branchId        String        @db.Uuid
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("AZN")
  transactionRef  String?
  providerPayload Json?
  idempotencyKey  String?       @unique
  cashShiftId     String?       @db.Uuid
  capturedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  order     Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branch    Branch     @relation(fields: [branchId], references: [id])
  cashShift CashShift? @relation(fields: [cashShiftId], references: [id])
  refunds   Refund[]

  @@index([orderId])
  @@index([status])
  @@index([method])
}

model Refund {
  id        String        @id @default(uuid()) @db.Uuid
  paymentId String        @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  reason    String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @unique @db.Uuid
  number    String   @unique
  fileUrl   String?
  pdfHash   String?
  issuedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model CashShift {
  id            String          @id @default(uuid()) @db.Uuid
  branchId      String          @db.Uuid
  openedById    String          @db.Uuid
  closedById    String?         @db.Uuid
  status        CashShiftStatus @default(OPEN)
  openingCash   Decimal         @default(0) @db.Decimal(12, 2)
  closingCash   Decimal?        @db.Decimal(12, 2)
  expectedCash  Decimal?        @db.Decimal(12, 2)
  diff          Decimal?        @db.Decimal(12, 2)
  openedAt      DateTime        @default(now())
  closedAt      DateTime?
  notes         String?

  branch   Branch    @relation(fields: [branchId], references: [id])
  openedBy User      @relation("CashShiftOpener", fields: [openedById], references: [id])
  closedBy User?     @relation("CashShiftCloser", fields: [closedById], references: [id])
  payments Payment[]

  @@index([branchId, status])
}

// =============================================================
// Bonuses
// =============================================================

model BonusWallet {
  id              String   @id @default(uuid()) @db.Uuid
  clientId        String   @unique @db.Uuid
  balance         Decimal  @default(0) @db.Decimal(12, 2)
  lifetimeEarned  Decimal  @default(0) @db.Decimal(12, 2)
  lifetimeSpent   Decimal  @default(0) @db.Decimal(12, 2)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model BonusTransaction {
  id            String      @id @default(uuid()) @db.Uuid
  clientId      String      @db.Uuid
  type          BonusTxType
  amount        Decimal     @db.Decimal(12, 2)
  sourceOrderId String?     @db.Uuid
  expiresAt     DateTime?
  note          String?
  createdAt     DateTime    @default(now())

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sourceOrder Order? @relation(fields: [sourceOrderId], references: [id])

  @@index([clientId, createdAt])
  @@index([expiresAt])
}

// =============================================================
// Inventory
// =============================================================

model InventoryItem {
  id        String   @id @default(uuid()) @db.Uuid
  branchId  String   @db.Uuid
  sku       String?
  name      String
  unit      String   @default("pcs")
  costAvg   Decimal  @default(0) @db.Decimal(12, 4)
  stockQty  Decimal  @default(0) @db.Decimal(12, 3)
  minStock  Decimal  @default(0) @db.Decimal(12, 3)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch        Branch                @relation(fields: [branchId], references: [id])
  movements     StockMovement[]
  consumption   ServiceConsumption[]
  usageRecords  OrderMaterialUsage[]

  @@unique([branchId, sku])
  @@index([branchId])
}

model ServiceConsumption {
  id        String   @id @default(uuid()) @db.Uuid
  serviceId String   @db.Uuid
  itemId    String   @db.Uuid
  qty       Decimal  @db.Decimal(12, 3)
  createdAt DateTime @default(now())

  service Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  item    InventoryItem @relation(fields: [itemId], references: [id])

  @@unique([serviceId, itemId])
}

model OrderMaterialUsage {
  id           String   @id @default(uuid()) @db.Uuid
  orderItemId  String   @db.Uuid
  itemId       String   @db.Uuid
  qtyPlanned   Decimal  @db.Decimal(12, 3)
  qtyActual    Decimal  @db.Decimal(12, 3)
  costSnapshot Decimal  @db.Decimal(12, 4)
  createdAt    DateTime @default(now())

  orderItem OrderItem     @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  item      InventoryItem @relation(fields: [itemId], references: [id])

  @@index([orderItemId])
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  branchId    String            @db.Uuid
  itemId      String            @db.Uuid
  type        StockMovementType
  qty         Decimal           @db.Decimal(12, 3)
  unitCost    Decimal?          @db.Decimal(12, 4)
  refOrderId  String?           @db.Uuid
  note        String?
  createdById String?           @db.Uuid
  createdAt   DateTime          @default(now())

  branch   Branch         @relation(fields: [branchId], references: [id])
  item     InventoryItem  @relation(fields: [itemId], references: [id])
  refOrder Order?         @relation(fields: [refOrderId], references: [id])

  @@index([itemId, createdAt])
  @@index([branchId, createdAt])
}

// =============================================================
// HR / Payroll
// =============================================================

model PayrollProfile {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @unique @db.Uuid
  modelType PayrollModelType
  params    Json
  startsAt  DateTime         @default(now())
  endsAt    DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalaryRun {
  id         String   @id @default(uuid()) @db.Uuid
  branchId   String   @db.Uuid
  periodFrom DateTime @db.Date
  periodTo   DateTime @db.Date
  status     String   @default("draft")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  branch Branch          @relation(fields: [branchId], references: [id])
  items  SalaryRunItem[]

  @@unique([branchId, periodFrom, periodTo])
}

model SalaryRunItem {
  id          String  @id @default(uuid()) @db.Uuid
  runId       String  @db.Uuid
  employeeId  String  @db.Uuid
  base        Decimal @db.Decimal(12, 2)
  bonus       Decimal @default(0) @db.Decimal(12, 2)
  deductions  Decimal @default(0) @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)
  details     Json?

  run SalaryRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, employeeId])
}

// =============================================================
// Notifications & Outbox
// =============================================================

model Notification {
  id            String              @id @default(uuid()) @db.Uuid
  recipientType String
  recipientId   String
  channel       NotificationChannel
  template      String
  payload       Json
  status        NotificationStatus  @default(PENDING)
  attempts      Int                 @default(0)
  lastError     String?
  sendAfter     DateTime            @default(now())
  sentAt        DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([status, sendAfter])
  @@index([recipientType, recipientId])
}

model OutboxEvent {
  id          String       @id @default(uuid()) @db.Uuid
  aggregate   String
  aggregateId String
  type        String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  lastError   String?
  processedAt DateTime?
  createdAt   DateTime     @default(now())

  @@index([status, createdAt])
  @@index([aggregate, aggregateId])
}
