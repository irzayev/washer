# ===========================================
# Core
# ===========================================
NODE_ENV=development
TZ=Asia/Baku

# ===========================================
# API (NestJS)
# ===========================================
API_PORT=4000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-please
JWT_ACCESS_TTL=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-please
JWT_REFRESH_TTL=30d

# ===========================================
# Database
# ===========================================
DATABASE_URL=postgresql://washer:washer@localhost:5432/washer?schema=public

# ===========================================
# Redis / BullMQ
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===========================================
# MinIO / S3
# ===========================================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=washer-uploads
S3_PUBLIC_URL=http://localhost:9000

# ===========================================
# WhatsApp (Evolution API)
# ===========================================
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=washer

# ===========================================
# Azericard (E-Commerce Gateway, RSA-SHA256)
# ===========================================
# mode: mock | sandbox | production
AZERICARD_MODE=mock
AZERICARD_MERCHANT_ID=
AZERICARD_TERMINAL_ID=
AZERICARD_MERCH_NAME=WASHER
AZERICARD_MERCH_URL=http://localhost:3000
AZERICARD_COUNTRY=AZ
AZERICARD_GMT=+4
# Sandbox: https://testmpi.3dsecure.az/cgi-bin/cgi_link
# Production: https://mpi.3dsecure.az/cgi-bin/cgi_link
AZERICARD_GATEWAY_URL=https://testmpi.3dsecure.az/cgi-bin/cgi_link
# 2048-bit RSA keypair. Generate via:
#   openssl genrsa -out merchant_private.pem 2048
#   openssl rsa -in merchant_private.pem -pubout -out merchant_public.pem
# Public key must be registered with Azericard. Path is absolute or relative to API cwd.
AZERICARD_PRIVATE_KEY_PATH=./secrets/merchant_private.pem
AZERICARD_GATEWAY_PUBLIC_KEY_PATH=./secrets/azericard_public.pem

# ===========================================
# LLM (local Ollama by default)
# ===========================================
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ===========================================
# Observability
# ===========================================
LOG_LEVEL=info
SENTRY_DSN=

# ===========================================
# Web (Next.js)
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Washer CRM
